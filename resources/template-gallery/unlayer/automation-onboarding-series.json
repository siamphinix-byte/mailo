        { "id": "row_header", "cells": [1], "columns": [{ "id": "col_header", "contents": [{ "id": "logo", "type": "image", "values": { "src": { "url": "https://via.placeholder.com/140x45/8B5CF6/FFFFFF?text=APP" }, "width": "140px", "textAlign": "center", "containerPadding": "25px 20px" } }] }], "values": { "backgroundColor": "#8B5CF6" } },
        { "id": "row_hero", "cells": [1], "columns": [{ "id": "col_hero", "contents": [
          { "id": "step_badge", "type": "text", "values": { "text": "<p style=\"display: inline-block; background: #EDE9FE; color: #7C3AED; padding: 6px 16px; border-radius: 20px; font-weight: 600; font-size: 12px;\">Step 1 of 5</p>", "textAlign": "center", "containerPadding": "30px 20px 15px 20px" } },
          { "id": "title", "type": "heading", "values": { "text": "Welcome to Your Journey! 🚀", "headingType": "h1", "fontSize": "28px", "fontWeight": 700, "textAlign": "center", "color": "#111827", "containerPadding": "0px 20px 15px 20px" } },
          { "id": "intro", "type": "text", "values": { "text": "<p style=\"color: #374151; line-height: 170%;\">Hi {{first_name}},</p><p style=\"color: #374151; line-height: 170%; margin-top: 10px;\">We're thrilled to have you on board! Over the next few days, we'll help you get the most out of our platform with quick tips and tutorials.</p>", "fontSize": "15px", "containerPadding": "0px 40px 25px 40px" } }
        ] }], "values": { "backgroundColor": "#FFFFFF" } },
        { "id": "row_task", "cells": [1], "columns": [{ "id": "col_task", "contents": [
          { "id": "task_title", "type": "heading", "values": { "text": "Today's Task: Complete Your Profile", "headingType": "h2", "fontSize": "20px", "fontWeight": 700, "color": "#111827", "containerPadding": "25px 30px 15px 30px" } },
          { "id": "task_desc", "type": "text", "values": { "text": "<p style=\"color: #6B7280; line-height: 160%;\">A complete profile helps us personalize your experience and connect you with the right features.</p>", "fontSize": "14px", "containerPadding": "0px 30px 15px 30px" } },
          { "id": "checklist", "type": "text", "values": { "text": "<div style=\"background: #F9FAFB; border-radius: 8px; padding: 15px;\"><p style=\"color: #374151; margin-bottom: 10px;\">☑️ Add your profile photo</p><p style=\"color: #374151; margin-bottom: 10px;\">☑️ Set your timezone</p><p style=\"color: #374151;\">☑️ Connect your first integration</p></div>", "containerPadding": "0px 30px 20px 30px" } },
          { "id": "start_btn", "type": "button", "values": { "text": "Complete Your Profile →", "href": { "name": "web", "values": { "href": "#", "target": "_blank" } }, "buttonColors": { "color": "#FFFFFF", "backgroundColor": "#8B5CF6" }, "borderRadius": "8px", "padding": "14px 32px", "textAlign": "center", "containerPadding": "0px 30px 25px 30px" } }
        ] }], "values": { "backgroundColor": "#FFFFFF" } },
        { "id": "row_help", "cells": [1], "columns": [{ "id": "col_help", "contents": [
          { "id": "help_text", "type": "text", "values": { "text": "<p style=\"color: #6B7280;\">💡 <strong>Need help?</strong> Check out our <a href=\"#\" style=\"color: #8B5CF6;\">Getting Started Guide</a> or reply to this email.</p>", "fontSize": "14px", "textAlign": "center", "containerPadding": "20px 30px" } }
        ] }], "values": { "backgroundColor": "#F5F3FF" } },
        { "id": "row_footer", "cells": [1], "columns": [{ "id": "col_footer", "contents": [{ "id": "footer", "type": "text", "values": { "text": "<p style=\"color: #9CA3AF;\">© 2026 Your App. All rights reserved.</p><p style=\"color: #6B7280; margin-top: 10px;\"><a href=\"#\" style=\"color: #6B7280;\">Unsubscribe</a></p>", "fontSize": "12px", "textAlign": "center", "containerPadding": "25px 20px" } }] }], "values": { "backgroundColor": "#1F2937" } }
      ],
      "values": { "backgroundColor": "#E5E7EB", "contentWidth": "600px", "fontFamily": { "label": "Inter", "value": "'Inter', sans-serif" } }
